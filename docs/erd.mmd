    Equipment ||--o{ WorkoutPlanItems : "używany w pozycji planu"
    Equipment ||--o{ EquipmentMuscles : "angażuje"
    Muscles ||--o{ EquipmentMuscles : "opisuje sprzęt"

    Equipment ||--o{ EquipmentExercises : "obsługuje"
    Exercises ||--o{ EquipmentExercises : "wykonywane na"

